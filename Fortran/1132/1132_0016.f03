PROGRAM CV2503
  COMMON /COM/ NN
  TYPE STR
     REAL *8 AA(20)
  END type STR
  TYPE(STR) STR_DATA

  NN=1
  DO I=1,20,NN
     STR_DATA%AA(I)=I
     CALL SUB
  END DO
  WRITE(6,*) ' *** CVCT2503_str ***'
  WRITE(6,*) STR_DATA%AA
  STOP
END PROGRAM CV2503

SUBROUTINE SUB
  RETURN
END SUBROUTINE SUB
